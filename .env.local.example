# Shop ID numérico que aparece no app Headless da Shopify
SHOPIFY_SHOP_ID=

# Client ID da Customer Account API (app Headless > Customer Account API)
SHOPIFY_CLIENT_ID=

# URL da app local
APP_URL=http://localhost:3000

# Segredo para assinar o cookie de sessão (gere qualquer string aleatória longa)
SESSION_SECRET=troque-isto-por-uma-string-aleatoria-longa
